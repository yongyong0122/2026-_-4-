import bpy
import bmesh
import math
from mathutils import Vector

N = 5
R = 10
rho = 1.0
overlap = 1.02

CURVE_STEPS = 512
TUBE_SIDES = 64

PALETTE = [
    (0.85, 0.10, 0.10, 1.0),
    (0.10, 0.40, 0.90, 1.0),
    (0.10, 0.75, 0.25, 1.0),
    (0.95, 0.72, 0.05, 1.0),
    (0.65, 0.15, 0.88, 1.0),
]

METALLIC = 0.15
ROUGHNESS = 0.35

r_tube = rho * math.sin(math.pi / N) * overlap

