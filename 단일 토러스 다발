cam_obj.location = Vector((0, -dist, dist * 0.2))
cam_obj.rotation_euler = (math.radians(82), 0, 0)

def add_area(name, loc, energy, color=(1, 1, 1), size=5.0):
    ld = bpy.data.lights.new(name, type='AREA')
    ld.energy = energy
    ld.color = color
    ld.size = size

    lo = bpy.data.objects.new(name, ld)
    lo.location = loc

    bpy.context.collection.objects.link(lo)

s = R * 3.5

add_area("Key",  (s*0.5, -s,      s*1.8), s**2*200, (1.00, 0.97, 0.93), s*1.5)
add_area("Fill", (-s*0.7, s*0.4,  s*0.7), s**2*70,  (0.80, 0.88, 1.00), s)
add_area("Rim",  (s*0.2,  s*0.7, -s*0.5), s**2*55,  (1.00, 0.99, 0.96), s*0.7)
add_area("Top",  (0,      0,      s*2.2), s**2*35,  (1.00, 1.00, 1.00), s*2)

world = bpy.context.scene.world or bpy.data.worlds.new("World")
bpy.context.scene.world = world

world.use_nodes = True

bg = world.node_tree.nodes.get("Background")

if bg:
    bg.inputs['Color'].default_value = (0.88, 0.86, 0.82, 1.0)
    bg.inputs['Strength'].default_value = 0.4

