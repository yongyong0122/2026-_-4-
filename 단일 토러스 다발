def clear_scene():
    bpy.ops.object.select_all(action='SELECT')
    bpy.ops.object.delete()
    for b in list(bpy.data.meshes):
        bpy.data.meshes.remove(b)
    for b in list(bpy.data.materials):
        bpy.data.materials.remove(b)

def make_material(name, rgba, metallic=0.0, roughness=0.5):
    mat = bpy.data.materials.new(name=name)
    mat.use_nodes = True
    nodes = mat.node_tree.nodes
    links = mat.node_tree.links
    nodes.clear()

    bsdf = nodes.new('ShaderNodeBsdfPrincipled')
    bsdf.inputs['Base Color'].default_value = rgba
    bsdf.inputs['Metallic'].default_value = metallic
    bsdf.inputs['Roughness'].default_value = roughness

    out = nodes.new('ShaderNodeOutputMaterial')
    links.new(bsdf.outputs['BSDF'], out.inputs['Surface'])
    return mat

def ring_path(k, N, R, rho, steps):
    pts = []
    phase = 2 * math.pi * k / N

    for i in range(steps):
        t = 2 * math.pi * i / steps
        phi = t + phase
        th = t

        x = (R + rho * math.cos(th)) * math.cos(phi)
        y = (R + rho * math.cos(th)) * math.sin(phi)
        z = rho * math.sin(th)

        pts.append(Vector((x, y, z)))

    return pts

def compute_rmf(pts):
    n = len(pts)

    tangs = []
    for i in range(n):
        dt = pts[(i + 1) % n] - pts[(i - 1) % n]
        tangs.append(dt.normalized())

    norms = [None] * n
    binorms = [None] * n

    t0 = tangs[0]
    arb = Vector((0, 0, 1)) if abs(t0.z) < 0.9 else Vector((1, 0, 0))

    n0 = t0.cross(arb).normalized()

    norms[0] = n0
    binorms[0] = tangs[0].cross(n0).normalized()

    for i in range(1, n):
        v1 = pts[i] - pts[i - 1]
        c1 = v1.dot(v1)

        if c1 < 1e-12:
            norms[i] = norms[i - 1]
            binorms[i] = binorms[i - 1]
            continue

        rL = norms[i - 1] - (2 / c1) * v1.dot(norms[i - 1]) * v1
        tL = tangs[i - 1] - (2 / c1) * v1.dot(tangs[i - 1]) * v1

        v2 = tangs[i] - tL
        c2 = v2.dot(v2)

        nL = rL if c2 < 1e-12 else rL - (2 / c2) * v2.dot(rL) * v2

        norms[i] = nL.normalized()
        binorms[i] = tangs[i].cross(norms[i]).normalized()

    dot = max(-1.0, min(1.0, norms[0].dot(norms[-1])))
    twist = math.acos(dot)

    if norms[-1].cross(norms[0]).dot(tangs[0]) < 0:
        twist = -twist

    for i in range(n):
        angle = twist * i / n
        axis = tangs[i]

        c = math.cos(angle)
        s = math.sin(angle)

        ni = norms[i]

        norms[i] = (
            ni * c
            + axis.cross(ni) * s
            + axis * axis.dot(ni) * (1 - c)
        ).normalized()

        binorms[i] = tangs[i].cross(norms[i]).normalized()

    return tangs, norms, binorms

def build_tube(name, pts, norms, binorms, r, sides):
    bm = bmesh.new()

    n = len(pts)
    vr = []

    for i in range(n):
        row = []

        for j in range(sides):
            a = 2 * math.pi * j / sides
            off = r * (
                math.cos(a) * norms[i]
                + math.sin(a) * binorms[i]
            )

            row.append(bm.verts.new(pts[i] + off))

        vr.append(row)

    bm.verts.ensure_lookup_table()

    for i in range(n):
        ni = (i + 1) % n

        for j in range(sides):
            nj = (j + 1) % sides

            bm.faces.new([
                vr[i][j],
                vr[i][nj],
                vr[ni][nj],
                vr[ni][j]
            ])

    mesh = bpy.data.meshes.new(name)

    bm.to_mesh(mesh)
    bm.free()
    mesh.update()

    for p in mesh.polygons:
        p.use_smooth = True

    return mesh

clear_scene()

for k in range(N):
    print(f"  고리 {k+1}/{N} ...", end=" ", flush=True)

    pts = ring_path(k, N, R, rho, CURVE_STEPS)
    tangs, norms, bnorms = compute_rmf(pts)

    mesh = build_tube(
        f"Ring_{k+1:02d}",
        pts,
        norms,
        bnorms,
        r_tube,
        TUBE_SIDES
    )

    obj = bpy.data.objects.new(f"Ring_{k+1:02d}", mesh)
    bpy.context.collection.objects.link(obj)

    mat = make_material(
        f"Mat_{k+1:02d}",
        PALETTE[k % len(PALETTE)],
        METALLIC,
        ROUGHNESS
    )

    obj.data.materials.append(mat)

    print("완료")

